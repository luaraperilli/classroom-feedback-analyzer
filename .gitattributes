# Auto-detect text files and normalize line endings to LF in the repository.
# Working tree files keep platform-native line endings (CRLF on Windows, LF on Unix).
* text=auto eol=lf

# Explicit text formats
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf
*.ipynb text eol=lf
*.bib   text eol=lf
*.tex   text eol=lf

# Shell scripts must keep LF
*.sh    text eol=lf

# Binary files (do not normalize)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.pdf   binary
*.db    binary
*.sqlite binary
*.zip   binary
*.gz    binary
*.tar   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
