# Exemplo de variáveis de ambiente — copie para ".env" e preencha.
# Em DESENVOLVIMENTO local você não precisa de nada disso (há fallbacks seguros).
# Estas variáveis são OBRIGATÓRIAS em PRODUÇÃO.

# Perfil: "development" (padrão) ou "production"
FLASK_CONFIG=production

# Chaves secretas — gere valores fortes e DISTINTOS, ex.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-aleatoria-forte
JWT_SECRET_KEY=troque-por-outra-chave-aleatoria-forte

# Origem(ns) do frontend autorizadas no CORS (separadas por vírgula, sem barra final)
CORS_ORIGINS=https://seu-frontend.vercel.app

# Banco de dados (opcional). Sem isto, usa SQLite local.
# Para Postgres: postgresql://usuario:senha@host:5432/nome_do_banco
# DATABASE_URL=

# Rede (opcional) — úteis em hospedagem
# HOST=0.0.0.0
# PORT=5001
